# =========================================================================
# SharePoint Migration Tool - environment configuration
# Copy to .env and fill in. Never commit the real .env file.
# Most of these values are printed out by setup/New-AppRegistration.ps1
# =========================================================================

# --- Tenant / app registration (shared by delegated + app-only auth) -----
TENANT_ID=
# Display-only tenant label (the setup script fills in your tenant's default
# domain automatically; leave empty rather than inventing a placeholder).
TENANT_NAME=
CLIENT_ID=

# --- Delegated auth (MSAL Node, Auth Code + PKCE) - used by the web UI ---
# Client secret for the confidential-client MSAL flow. Short-lived tokens
# only (the interactive user's own session) - NOT used by the engine.
CLIENT_SECRET=
REDIRECT_URI=http://localhost:3000/auth/redirect
POST_LOGOUT_REDIRECT_URI=http://localhost:3000
# Space separated. Sites.FullControl.All is needed for the in-app "grant
# migration engine access to this site" button (calls Graph's POST
# /sites/{id}/permissions on the admin's behalf) - not for browsing itself.
DELEGATED_SCOPES=openid profile email offline_access User.Read Sites.Read.All Files.Read.All Sites.FullControl.All

# --- App-only auth (certificate) - used by the PnP.PowerShell engine ----
# Path to the PFX/PEM private key generated by setup/New-AppRegistration.ps1
ENGINE_CERT_THUMBPRINT=
ENGINE_CERT_PATH=./setup/certs/migration-engine.pfx
# If Sites.Selected proves too restrictive for some source sites, the
# fallback is tenant-wide Sites.ReadWrite.All - see setup/README below.
ENGINE_PERMISSION_MODE=Sites.Selected

# --- Session / cookie signing ---------------------------------------------
SESSION_SECRET=change-me-to-a-long-random-string

# --- Server ----------------------------------------------------------------
PORT=3000
NODE_ENV=development

# --- SQLite ------------------------------------------------------------
SQLITE_DB_PATH=./data/migration.db

# --- Concurrency / throttling defaults (overridable per job in the UI) ---
DEFAULT_JOB_CONCURRENCY=4
GLOBAL_MAX_CONCURRENCY=12
RETRY_RATE_BACKOFF_THRESHOLD=0.20
SLOW_TRANSFER_THRESHOLD_MS=30000

# --- PowerShell engine -----------------------------------------------------
PWSH_EXECUTABLE=pwsh
ENGINE_SCRIPT_PATH=./engine/Invoke-MigrationJob.ps1

# --- Azure Blob archive target (optional) ---------------------------------
# Full connection string for the storage account used as an archive
# destination (Azure Portal -> Storage account -> Access keys). Leave empty
# to disable the "Azure Blob container" target option entirely - it's then
# hidden in the UI and rejected server-side if a job somehow requests it.
AZURE_BLOB_CONNECTION_STRING=

# --- File share (DFS) migration source (optional fallback) -----------------
# File-share source roots are normally managed per-project on the Settings
# page - no .env edit needed. This optional variable adds server-wide roots
# on top (semicolon-separated), e.g.:
#   FS_SOURCE_ROOTS=\\corp\dfs\Departments;\\filesrv\Archive
# The server process account - not the signed-in user - reads the shares, so
# it needs read access to every root. Roots listed here are visible to EVERY
# project on this instance; prefer the per-project Settings page.
FS_SOURCE_ROOTS=

# --- Per-project engine credential encryption ------------------------------
# Encrypts each Project's auto-provisioned, tenant-local engine app secret
# at rest in SQLite. Generate once with `openssl rand -base64 32` and never
# change it afterward - changing it makes every already-stored per-project
# secret undecryptable.
CREDENTIAL_ENCRYPTION_KEY=
