# =========================================================================
# SharePoint Migration Tool - environment configuration
# Copy to .env and fill in. Never commit the real .env file.
# Most of these values are printed out by setup/New-AppRegistration.ps1
# =========================================================================

# --- Tenant / app registration (shared by delegated + app-only auth) -----
TENANT_ID=
# Display-only tenant label (the setup script fills in your tenant's default
# domain automatically; leave empty rather than inventing a placeholder).
TENANT_NAME=
CLIENT_ID=

# --- Delegated auth (MSAL Node, Auth Code + PKCE) - used by the web UI ---
# Client secret for the confidential-client MSAL flow. Short-lived tokens
# only (the interactive user's own session) - NOT used by the engine.
CLIENT_SECRET=
REDIRECT_URI=http://localhost:3000/auth/redirect
POST_LOGOUT_REDIRECT_URI=http://localhost:3000
# Space separated. Sites.FullControl.All is needed for the in-app "grant
# migration engine access to this site" button (calls Graph's POST
# /sites/{id}/permissions on the admin's behalf) - not for browsing itself.
# When the OneDrive target is enabled (-EnableOneDriveTarget), the setup
# script also adds User.Read.All here - the OneDrive picker's user search
# (GET /users?$search=) needs it.
DELEGATED_SCOPES=openid profile email offline_access User.Read Sites.Read.All Files.Read.All Sites.FullControl.All

# --- App-only auth (certificate) - used by the PnP.PowerShell engine ----
# Path to the PFX/PEM private key generated by setup/New-AppRegistration.ps1
ENGINE_CERT_THUMBPRINT=
ENGINE_CERT_PATH=./setup/certs/migration-engine.pfx
# If Sites.Selected proves too restrictive for some source sites, the
# fallback is tenant-wide Sites.ReadWrite.All - see setup/README below.
ENGINE_PERMISSION_MODE=Sites.Selected

# --- Session / cookie signing ---------------------------------------------
SESSION_SECRET=change-me-to-a-long-random-string

# --- Team access & roles ----------------------------------------------------
# NOTE on consent: a bare sign-in (no project) is an IDENTITY login and only
# asks for User.Read - teammates see a one-line consent, not the full
# DELEGATED_SCOPES wall. The working scopes above are requested when opening
# a project (/auth/login?project=), which is also when a new client tenant is
# onboarded: create the project on the /projects page, then sign into it with
# that tenant's GA account (or a team guest account with equivalent rights).
# Restrict who may sign in at all, by account DOMAIN (comma/space-separated,
# case-insensitive). Matched against the authenticated account's UPN/email,
# including the un-mangled home UPN of B2B guest accounts - so your team's
# knowall.net users are recognized even when signing into a client tenant
# they're guests in. Empty = anyone with a Microsoft work account may sign in
# (the pre-team behaviour). NOTE: checked on EVERY sign-in leg, including a
# client tenant GA signing in to consent/provision - list their domain too if
# they need to sign in themselves.
#ALLOWED_LOGIN_DOMAINS=knowall.net

# UPNs force-promoted to the 'admin' role at every login. Admins see every
# user's mappings/jobs/dashboards; members see only their own (plus rows
# created before ownership existed). Users who existed before this feature
# are grandfathered as admin automatically.
#ADMIN_UPNS=you@knowall.net

# --- Server ----------------------------------------------------------------
PORT=3000
NODE_ENV=development

# --- SQLite ------------------------------------------------------------
SQLITE_DB_PATH=./data/migration.db

# --- Concurrency / throttling defaults (overridable per job in the UI) ---
DEFAULT_JOB_CONCURRENCY=4
GLOBAL_MAX_CONCURRENCY=12
RETRY_RATE_BACKOFF_THRESHOLD=0.20
SLOW_TRANSFER_THRESHOLD_MS=30000

# --- PowerShell engine -----------------------------------------------------
PWSH_EXECUTABLE=pwsh
ENGINE_SCRIPT_PATH=./engine/Invoke-MigrationJob.ps1

# --- Azure Blob archive target (optional) ---------------------------------
# Full connection string for the storage account used as an archive
# destination (Azure Portal -> Storage account -> Access keys). Leave empty
# to disable the "Azure Blob container" target option entirely - it's then
# hidden in the UI and rejected server-side if a job somehow requests it.
AZURE_BLOB_CONNECTION_STRING=

# --- OneDrive migration target (optional) -----------------------------------
# Lets a mapping target a specific named user's OneDrive instead of a
# SharePoint library or Blob container. Unlike the Blob target this needs no
# connection string - it rides the engine's existing app-only cert - but that
# cert's app registration must additionally hold the Files.ReadWrite.All
# Graph application permission (grant it by re-running
# setup/New-AppRegistration.ps1 with -EnableOneDriveTarget). That permission
# is TENANT-WIDE standing file access (every OneDrive and SharePoint site),
# a materially bigger grant than the Sites.Selected model everything else
# here uses - see COMPLIANCE.md before enabling this in production. Leave
# false to disable the "OneDrive" target option entirely - it's then hidden
# in the UI and rejected server-side if a job somehow requests it.
ENGINE_ONEDRIVE_TARGET_ENABLED=false

# --- File share (DFS) migration source (optional fallback) -----------------
# File-share source roots are normally managed per-project on the Settings
# page - no .env edit needed. This optional variable adds server-wide roots
# on top (semicolon-separated), e.g.:
#   FS_SOURCE_ROOTS=\\corp\dfs\Departments;\\filesrv\Archive
# The server process account - not the signed-in user - reads the shares, so
# it needs read access to every root. Roots listed here are visible to EVERY
# project on this instance; prefer the per-project Settings page.
FS_SOURCE_ROOTS=

# Server-side BOUND on the per-project file-share allowlists (recommended
# whenever file-share sources are used): every root added on any project's
# Settings page must live under one of these parents, so a signed-in project
# user can never point the service account at arbitrary server paths.
# Semicolon-separated, e.g. \\10.5.92.10\Fastdata$;\\filesrv\Migrations
FS_SOURCE_ALLOWED_PARENTS=

# --- Per-project engine credential encryption ------------------------------
# Encrypts each Project's auto-provisioned, tenant-local engine app secret
# at rest in SQLite. Generate once with `openssl rand -base64 32` and never
# change it afterward - changing it makes every already-stored per-project
# secret undecryptable.
CREDENTIAL_ENCRYPTION_KEY=
